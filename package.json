{
  "name": "visual-ai-assertions",
  "version": "0.5.0",
  "description": "AI-powered visual assertions for E2E tests — send screenshots to Claude, GPT, or Gemini and get structured results",
  "author": "Risko Ruus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nullp2ike/visual-reasoning.git"
  },
  "homepage": "https://github.com/nullp2ike/visual-reasoning#readme",
  "bugs": {
    "url": "https://github.com/nullp2ike/visual-reasoning/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:smoke": "vitest run --config vitest.config.smoke.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.typecheck.json",
    "prepare": "husky"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/genai": ">=0.1.0",
    "openai": ">=4.60.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "lint-staged": {
    "*.{ts,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "visual-testing",
    "ai-assertions",
    "playwright",
    "webdriverio",
    "e2e-testing",
    "screenshot-testing",
    "claude",
    "gpt",
    "gemini"
  ],
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
